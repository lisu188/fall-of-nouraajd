{
  "kadathStart": {
    "class": "StartEvent",
    "properties": {
      "text": "The dream carries you onto the Cold Waste, and there is no waking now. A road of black basalt climbs north through a snow that has never thawed, past the Plateau of Leng and ruins older than the first sleeper, to the onyx castle of the Great Ones on unknown Kadath. Something in that castle has been waiting for a dreamer bold enough to climb. It is not one of the Great Ones."
    }
  },
  "kadathSign": {
    "ref": "signPost",
    "properties": {
      "text": "UNKNOWN KADATH - the cold waste. Climb if you must. The Great Ones no longer answer; only their soul and messenger does."
    }
  },
