  "onyxSignetOfNyarlathotep": {
    "class": "CHelmet",
    "properties": {
      "animation": "images/items/helmets/crownofnightmares",
      "label": "Onyx Signet of the Crawling Chaos",
      "description": "A circlet of black onyx pressed with the seal of the soul and messenger of the Other Gods. It floods the mind with the cold clarities of the outer void, but the will it feeds is no longer wholly the wearer's, and the onyx will not leave the brow until the curse is broken.",
      "power": 20,
      "tags": [
        "cursed",
        "quest"
      ],
      "bonus": {
        "class": "CStats",
        "properties": {
          "agility": 6,
          "crit": 10,
          "intelligence": 18,
          "normalResist": -12,
          "stamina": -10,
          "strength": 3
        }
      }
    }
  },
  "kadathAscentQuest": {
    "class": "KadathAscentQuest",
    "properties": {
      "description": "Climb the Cold Waste to the onyx castle of Kadath and learn what waits upon its throne."
    }
  },
  "ambientCampCairn": {
    "ref": "signPost",
    "properties": {
      "animation": "images/ambient/rubble_and_skulls",
      "canStep": true,
      "text": "A cairn of the dreamers who tried the climb. Each stone is a name; none of the names ever woke."
    }
  },
  "ambientDreamerWarning": {
    "ref": "signPost",
    "properties": {
      "animation": "images/ambient/notice_board",
      "canStep": true,
      "text": "DREAMER'S WARNING - Do not seek the Great Ones. They have forgotten their own castle, and their guardian has not."
    }
  },
  "ambientFrozenPilgrim": {
    "ref": "signPost",
    "properties": {
      "animation": "images/ambient/dead_tree",
      "canStep": true,
      "text": "A pilgrim sits frozen mid-stride, still facing north, a smile of terrible welcome fixed on his blue lips."
    }
  },
  "ambientSilverKey": {
    "ref": "signPost",
    "properties": {
      "animation": "images/ambient/gravestone_cluster",
      "canStep": true,
      "text": "Scratched into ice: with the Silver Key a man may pass the Gate of Deeper Slumber, but no key locks the way back."
    }
  },
  "ambientNightGauntRoost": {
    "ref": "signPost",
    "properties": {
      "animation": "images/ambient/dead_tree",
      "canStep": true,
      "text": "Barbed, faceless, and cold to the touch - the Night-Gaunts do not harm you here. They only tickle, and carry, and leave you where the deeper things wait."
    }
  },
  "ambientChasmWarning": {
    "ref": "signPost",
    "properties": {
      "animation": "images/ambient/broken_fence",
      "canStep": true,
      "text": "The ice here is thin over a crevasse without a bottom. Below, a faint piping keeps a rhythm no living thing taught it."
    }
  },
  "ambientLengGate": {
    "ref": "signPost",
    "properties": {
      "animation": "images/ambient/broken_fence",
      "canStep": true,
      "text": "Here the waste gives onto the Plateau of Leng. Travelers are advised the folk of Leng are not folk, and their feast is not shared."
    }
  },
  "ambientLengHymn": {
    "ref": "signPost",
    "properties": {
      "animation": "images/ambient/brazier",
      "canStep": true,
      "text": "A prayer-post of Leng, greasy with tallow: we wear the faces we borrowed, and we do not take them off to eat."
    }
  },
  "ambientLengMasks": {
    "ref": "signPost",
    "properties": {
      "animation": "images/ambient/market_stall",
      "canStep": true,
      "text": "A stall of Leng where the almost-men trade in turbans and wide, fixed masks. Do not ask what the masks are hiding."
    }
  },
  "ambientElderGlyphs": {
    "ref": "signPost",
    "properties": {
      "animation": "images/ambient/dead_tree",
      "canStep": true,
      "text": "The ruin walls are cut with dot-groups of a star-headed race that built cities before there were men to dream them."
    }
  },
  "ambientElderShoggoth": {
    "ref": "signPost",
    "properties": {
      "animation": "images/ambient/rubble_and_skulls",
      "canStep": true,
      "text": "A frieze shows the Elder Things fleeing a black, bubbling servant that learned to shape itself. Beneath it, a fresher scrawl: it is still here. Tekeli-li."
    }
  },
  "ambientElderRetreat": {
    "ref": "signPost",
    "properties": {
      "animation": "images/ambient/gravestone_cluster",
      "canStep": true,
      "text": "The last glyphs record a retreat into the deeper dark. Even the builders of the world knew when to stop climbing."
    }
  },
  "ambientCyclopeanStair": {
    "ref": "signPost",
    "properties": {
      "animation": "images/ambient/stone_shrine",
      "canStep": true,
      "text": "The basalt road becomes a stair too vast for human legs, worn smooth by feet that were never feet."
    }
  },
  "ambientOtherGods": {
    "ref": "signPost",
    "properties": {
      "animation": "images/ambient/stone_well",
      "canStep": true,
      "text": "A shrine to the Other Gods, whose faces are veiled. They do not rule; they only devour, and their soul goes masked among them."
    }
  },
  "ambientNyarlathotep": {
    "ref": "signPost",
    "properties": {
      "animation": "images/ambient/brazier",
      "canStep": true,
      "text": "One name is cut deeper than the rest, again and again, by many hands: NYARLATHOTEP. The Crawling Chaos. He comes when the dreamer arrives, wearing a pleasant face."
    }
  },
  "ambientOnyxGate": {
    "ref": "signPost",
    "properties": {
      "animation": "images/ambient/broken_fence",
      "canStep": true,
      "text": "The onyx gate of the castle stands open. It has always stood open. Nothing needs to keep a dreamer out who has climbed this far."
    }
  },
  "ambientGreatOnes": {
    "ref": "signPost",
    "properties": {
      "animation": "images/ambient/wooden_bench",
      "canStep": true,
      "text": "The Great Ones - the gods of earth's dream - are gone from their thrones, wandered off to a sunset city they loved too well. Only their servant kept the appointment."
    }
  },
  "ambientAzathoth": {
    "ref": "signPost",
    "properties": {
      "animation": "images/ambient/campfire_cauldron",
      "canStep": true,
      "text": "At the center of ultimate chaos, the sign warns, the blind idiot god Azathoth gnaws hungrily in inconceivable dark. Do not let the messenger take you there."
    }
  },
  "ambientStarlessNight": {
    "ref": "signPost",
    "properties": {
      "animation": "images/ambient/street_lantern",
      "canStep": true,
      "text": "There are no stars over Kadath. There never were. The dark above the castle is the underside of somewhere else."
    }
  },
  "ambientDreamsEnd": {
    "ref": "signPost",
    "properties": {
      "animation": "images/ambient/gravestone_cluster",
      "canStep": true,
      "text": "Last marker before the throne: whatever it offers you on the onyx seat, remember that waking was always the braver quest."
    }
  },
  "ambientColdWaste": {
    "ref": "signPost",
    "properties": {
      "animation": "images/ambient/signpost",
      "canStep": true,
      "text": "COLD WASTE - no fuel, no game, no mercy. The only warmth on this road heals the body and asks nothing. Distrust it."
    }
  },
  "ambientNorthRoost": {
    "ref": "signPost",
    "properties": {
      "animation": "images/ambient/dead_tree",
      "canStep": true,
      "text": "Guano and shed barbs cake the north crag. Look up only if you are ready to be carried."
    }
  }
}
