  "amuletQuest": {
    "class": "AmuletQuest",
    "properties": {
      "description": "Find the stolen amulet for the old woman."
    }
  },
  "questDialog": {
    "class": "QuestDialog",
    "properties": {
      "states": [
        {
          "class": "CDialogState",
          "properties": {
            "stateId": "ENTRY",
            "text": "As you weave through the village, a withered woman wrings her hands beneath a sagging awning. Desperation clings to her like smoke.",
            "options": [
              {
                "class": "CDialogOption",
                "properties": {
                  "number": 0,
                  "nextStateId": "OLD_WOMAN_HELLO",
                  "text": "Approach the old woman and ask what burdens her."
                }
              },
              {
                "ref": "exitOption",
                "properties": {
                  "number": 1
                }
              }
            ]
          }
        },
        {
          "class": "CDialogState",
          "properties": {
            "stateId": "OLD_WOMAN_HELLO",
            "text": "Oh, traveler... the goblins in the nearby grove stole my family amulet. Generations prayed over it, and now it's vanished into their claws.",
            "options": [
              {
                "class": "CDialogOption",
                "properties": {
                  "number": 0,
                  "nextStateId": "ACCEPT_QUEST",
                  "text": "I'll hunt down the goblin and bring your talisman home."
                }
              },
              {
                "class": "CDialogOption",
                "properties": {
                  "number": 1,
                  "nextStateId": "DECLINE_QUEST",
                  "text": "I'm sorry. That path is closed to me."
                }
              }
            ]
          }
        },
        {
          "class": "CDialogState",
          "properties": {
            "stateId": "ACCEPT_QUEST",
            "text": "Thank you. The goblins are quick and mean as knives—please be careful when you seek them.",
            "options": [
              {
                "ref": "exitOption",
                "properties": {
                  "number": 0,
                  "action": "start_amulet_quest"
                }
              }
            ]
          }
        },
        {
          "class": "CDialogState",
          "properties": {
            "stateId": "DECLINE_QUEST",
            "text": "I understand. I'll keep praying that some soul answers this plea.",
            "options": [
              {
                "ref": "exitOption",
                "properties": {
                  "number": 0
                }
              }
            ]
          }
        }
      ]
    }
  },
  "questReturnDialog": {
    "class": "QuestReturnDialog",
    "properties": {
