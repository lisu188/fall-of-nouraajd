{
  "dialog": {
    "class": "OctoBogzDialog",
    "properties": {
      "states": [
        {
          "class": "CDialogState",
          "properties": {
            "stateId": "ENTRY",
            "text": "Hold a moment, stranger. Are you bound for the eastern road beyond the river?",
            "options": [
              {
                "class": "CDialogOption",
                "properties": {
                  "number": 0,
                  "nextStateId": "ASK_WHY",
                  "text": "Aye. Why the warning?"
                }
              },
              {
                "class": "CDialogOption",
                "properties": {
                  "number": 1,
                  "nextStateId": "ASK_WHY",
                  "text": "I'm unsure. What troubles you?"
                }
              }
            ]
          }
        },
        {
          "class": "CDialogState",
          "properties": {
            "stateId": "ASK_WHY",
            "text": "Be careful. A cave out there seethes with OctoBogz—twisted things part octopus, part hare, all shadowcraft. They lash caravans with Abyssal Shadows and leave bones in the sand.",
            "options": [
              {
                "class": "CDialogOption",
                "properties": {
                  "number": 0,
                  "nextStateId": "ASK_ABOUT_OCTOBOGZ",
                  "text": "Tell me more about these OctoBogz."
                }
              },
              {
                "class": "CDialogOption",
                "properties": {
                  "number": 1,
                  "nextStateId": "OFFER_HELP",
                  "text": "How can I help?"
                }
              }
            ]
          }
        },
        {
          "class": "CDialogState",
          "properties": {
            "stateId": "ASK_ABOUT_OCTOBOGZ",
            "text": "They're clever and quick, ambushing from stone and sand alike. Their tentacles strike far, and the Abyssal Shadows they fling strip the warmth from flesh.",
            "options": [
              {
                "class": "CDialogOption",
                "properties": {
                  "number": 0,
                  "nextStateId": "OFFER_HELP",
                  "text": "How can I help?"
                }
              }
            ]
          }
        },
        {
          "class": "CDialogState",
          "properties": {
            "stateId": "OFFER_HELP",
            "text": "Those of us who escaped have pooled what coin we have. We'll pay generously if someone dares that cave and ends the OctoBogz blight.",
            "options": [
              {
                "class": "CDialogOption",
                "properties": {
                  "number": 0,
                  "nextStateId": "ACCEPT_QUEST",
                  "action": "accept_quest",
                  "text": "I'll see the cave purged of OctoBogz."
                }
              },
              {
                "class": "CDialogOption",
                "properties": {
                  "number": 1,
                  "nextStateId": "DECLINE_QUEST",
                  "text": "Not now, but I'll remember."
                }
              }
            ]
          }
        },
        {
          "class": "CDialogState",
          "properties": {
            "stateId": "ACCEPT_QUEST",
            "text": "Head east across the river. The cave is half-buried under boulders and sand; follow the guttural echoes and you'll find it.",
            "options": [
              {
                "ref": "exitOption",
                "properties": {
                  "number": 0
                }
              }
            ]
          }
        },
        {
          "class": "CDialogState",
          "properties": {
            "stateId": "DECLINE_QUEST",
            "text": "Thank you for listening. May another blade take pity if you will not. Safe travels.",
            "options": [
              {
                "ref": "exitOption",
                "properties": {
                  "number": 0
                }
              }
            ]
          }
        }
      ]
    }
  }
}
