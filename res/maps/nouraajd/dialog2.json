{
  "dialog": {
    "class": "OctoBogzDialog",
    "properties": {
      "states": [
        {
          "class": "CDialogState",
          "properties": {
            "stateId": "ENTRY",
            "text": "Hold a moment, stranger. Are you bound for the eastern road beyond the river?",
            "options": [
              {
                "class": "CDialogOption",
                "properties": {
                  "number": 0,
                  "condition": "contract_not_started",
                  "nextStateId": "ASK_WHY",
                  "text": "Aye. Why the warning?"
                }
              },
              {
                "class": "CDialogOption",
                "properties": {
                  "number": 1,
                  "condition": "contract_not_started",
                  "nextStateId": "ASK_WHY",
                  "text": "I'm unsure. What troubles you?"
                }
              },
              {
                "class": "CDialogOption",
                "properties": {
                  "number": 2,
                  "condition": "contract_active",
                  "nextStateId": "ACTIVE_REMINDER",
                  "text": "I'm still hunting the OctoBogz. Anything more I should know?"
                }
              },
              {
                "class": "CDialogOption",
                "properties": {
                  "number": 3,
                  "condition": "contract_completed",
                  "action": "accept_quest",
                  "nextStateId": "COMPLETED_THANKS",
                  "text": "The cave is quiet now. The OctoBogz are dead."
                }
              },
              {
                "ref": "exitOption",
                "properties": {
                  "number": 4
                }
              }
            ]
          }
        },
        {
          "class": "CDialogState",
          "properties": {
            "stateId": "ASK_WHY",
            "text": "Be careful. A cave out there seethes with OctoBogz—twisted things part octopus, part hare, all shadowcraft. They lash caravans with Abyssal Shadows and leave bones in the mire.",
            "options": [
              {
                "class": "CDialogOption",
                "properties": {
                  "number": 0,
                  "nextStateId": "ASK_ABOUT_OCTOBOGZ",
                  "text": "Tell me more about these OctoBogz."
                }
              },
              {
                "class": "CDialogOption",
                "properties": {
                  "number": 1,
                  "nextStateId": "OFFER_HELP",
                  "text": "How can I help?"
                }
              }
            ]
          }
        },
        {
          "class": "CDialogState",
          "properties": {
            "stateId": "ASK_ABOUT_OCTOBOGZ",
            "text": "They're clever and quick, ambushing from reed and mud alike. Their tentacles strike far, and the Abyssal Shadows they fling strip the warmth from flesh.",
            "options": [
              {
                "class": "CDialogOption",
                "properties": {
                  "number": 0,
                  "nextStateId": "OFFER_HELP",
                  "text": "How can I help?"
                }
              }
            ]
          }
        },
        {
          "class": "CDialogState",
          "properties": {
            "stateId": "OFFER_HELP",
            "text": "Those of us who escaped have pooled what coin we have. We'll pay generously if someone dares that cave and ends the OctoBogz blight.",
            "options": [
              {
                "class": "CDialogOption",
                "properties": {
                  "number": 0,
                  "condition": "contract_not_started",
                  "nextStateId": "ACCEPT_QUEST",
                  "action": "accept_quest",
                  "text": "I'll see the cave purged of OctoBogz."
                }
              },
              {
                "class": "CDialogOption",
                "properties": {
                  "number": 1,
                  "nextStateId": "DECLINE_QUEST",
                  "text": "Not now, but I'll remember."
                }
              }
            ]
          }
        },
        {
          "class": "CDialogState",
          "properties": {
            "stateId": "ACCEPT_QUEST",
            "text": "Head east across the river. The cave is half-sunk under boulders and silt; follow the guttural echoes and you'll find it.",
            "options": [
              {
                "ref": "exitOption",
                "properties": {
                  "number": 0
                }
              }
            ]
          }
        },
        {
          "class": "CDialogState",
          "properties": {
            "stateId": "DECLINE_QUEST",
            "text": "Thank you for listening. May another blade take pity if you will not. Safe travels.",
            "options": [
              {
                "ref": "exitOption",
                "properties": {
                  "number": 0
                }
              }
            ]
          }
        },
        {
          "class": "CDialogState",
          "properties": {
            "stateId": "ACTIVE_REMINDER",
            "text": "You've already given us your word, and we've not forgotten it. The cave lies east across the river, half-sunk under boulders and silt—follow the guttural echoes. Come back when the OctoBogz are ash.",
            "options": [
              {
                "ref": "exitOption",
                "properties": {
                  "number": 0
                }
              }
            ]
          }
        },
        {
          "class": "CDialogState",
          "properties": {
            "stateId": "COMPLETED_THANKS",
            "text": "Then it's true—the eastern road is safe again. You've done what none of us dared. The refugees will speak your name for years. Go in peace; our debt to you is paid in full.",
            "options": [
              {
                "ref": "exitOption",
                "properties": {
                  "number": 0
                }
              }
            ]
          }
        }
      ]
    }
  }
}
