{
  "marchStart": {
    "class": "StartEvent",
    "properties": {
      "text": "You cross into the Sundered March, a war-broken borderland east of Nouraajd where three cursed dominions meet. A basalt road climbs north to a barred iron gate; beyond it the Barrow-Fen rots to the west and the Pyre-Waste smoulders to the east. Old warlords are buried under the central barrow, and the plague-cult of Marumi Baso means to crown one of them again. Take the key, take the passes, and take the crown before they do."
    }
  },
  "marchSign": {
    "ref": "signPost",
    "properties": {
      "text": "THE SUNDERED MARCH - vale south, fen west, waste east, barrow at the heart. The gate wants a key. The crown wants a bearer."
    }
  },
