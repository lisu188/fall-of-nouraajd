  "sunderedMarchQuest": {
    "class": "SunderedMarchQuest",
    "properties": {
      "description": "Claim the iron key, cross the barred pass, read the three obelisks, and unearth the crown beneath the barrow."
    }
  },
  "seerHuntQuest": {
    "class": "SeerHuntQuest",
    "properties": {
      "description": "Recover the War-Banner from the Barrow-Fen and bring it to the Seer of the Pyre-Waste."
    }
  },
  "ambientValeMuster": {
    "ref": "signPost",
    "properties": {
      "animation": "images/ambient/notice_board",
      "canStep": true,
      "text": "MUSTER ROLL - every name struck through. The March called its levies twice; neither host came home to be counted."
    }
  },
  "ambientValeGallows": {
    "ref": "signPost",
    "properties": {
      "animation": "images/ambient/dead_tree",
      "canStep": true,
      "text": "A gallows-tree hung with old rope and older warnings. Deserters here were given to the fen, not the grave."
    }
  },
  "ambientValeRefugees": {
    "ref": "signPost",
    "properties": {
      "animation": "images/ambient/supply_pile",
      "canStep": true,
      "text": "A refugee camp, long abandoned. They fled the plague east and the dead west, and met the cult in the middle."
    }
  },
  "ambientKeymaster": {
    "ref": "signPost",
    "properties": {
      "animation": "images/ambient/broken_cart",
      "canStep": true,
      "text": "The March Keeper kept every gate on one ring. He kept the last key on his own corpse; look to his cache."
    }
  },
  "ambientGateWarning": {
    "ref": "signPost",
    "properties": {
      "animation": "images/ambient/broken_fence",
      "canStep": true,
      "text": "BARRED PASS - the iron gate opens to the Keeper's key alone. Batter it and the peaks will answer for you."
    }
  },
  "ambientMonolithWarn": {
    "ref": "signPost",
    "properties": {
      "animation": "images/ambient/stone_well",
      "canStep": true,
      "text": "A twinned monolith of black glass. Step within and the far stone spits you out across the Sundered River. Mind you remember which is which."
    }
  },
  "ambientBarrowKings": {
    "ref": "signPost",
    "properties": {
      "animation": "images/ambient/gravestone_cluster",
      "canStep": true,
      "text": "Under this barrow lie the crowned dead of the March, king atop warlord atop thief, each buried with the one below's crown."
    }
  },
  "ambientDigWarning": {
    "ref": "signPost",
    "properties": {
      "animation": "images/ambient/rubble_and_skulls",
      "canStep": true,
      "text": "DIG WARNING - the ground gives up its king only to a reader of all three obelisks. To dig blind is to feed the barrow for nothing."
    }
  },
  "ambientObeliskCreed": {
    "ref": "signPost",
    "properties": {
      "animation": "images/ambient/notice_board",
      "canStep": true,
      "text": "Cult creed: three sigils, three dominions, one crown. Read the vale, the fen, and the pyre, and the March will kneel again."
    }
  },
  "ambientFenPlague": {
    "ref": "signPost",
    "properties": {
      "animation": "images/ambient/broken_fence",
      "canStep": true,
      "text": "PLAGUE FEN - the water remembers every drowned soldier and lends them out by night. Boil nothing you draw from here."
    }
  },
  "ambientFenDrowned": {
    "ref": "signPost",
    "properties": {
      "animation": "images/ambient/stone_well",
      "canStep": true,
      "text": "A drowned barrow, its capstone floating. The fen keeps the War-Banner down here, wrapped around a colonel who won't let go."
    }
  },
  "ambientBannerCreed": {
    "ref": "signPost",
    "properties": {
      "animation": "images/ambient/supply_pile",
      "canStep": true,
      "text": "Names sewn on the banner's hem in a dead hand: bring it whole to the Seer, and she will trade you a secret for a shroud."
    }
  },
  "ambientPyreHeretics": {
    "ref": "signPost",
    "properties": {
      "animation": "images/ambient/brazier",
      "canStep": true,
      "text": "PYRE-WASTE - the cult burns its own here to feed the crowning-rite. The ash never settles; it is always looking for a wind."
    }
  },
  "ambientPyreAsh": {
    "ref": "signPost",
    "properties": {
      "animation": "images/ambient/campfire_cauldron",
      "canStep": true,
      "text": "An ash-shrine to Marumi Baso, patient in the smoke. Its cauldron is kept warm for the day a crowned king walks out of the barrow."
    }
  },
  "ambientSeerRiddle": {
    "ref": "signPost",
    "properties": {
      "animation": "images/ambient/stone_shrine",
      "canStep": true,
      "text": "The Seer of the Pyre-Waste speaks only in trade: a banner for a boon, a corpse's name for a living one's fate."
    }
  },
  "ambientCrownLegend": {
    "ref": "signPost",
    "properties": {
      "animation": "images/ambient/gravestone_cluster",
      "canStep": true,
      "text": "They say the crown makes a warlord of whoever digs it up. They do not say the warlord it makes is not you."
    }
  },
  "ambientWarlordEpitaph": {
    "ref": "signPost",
    "properties": {
      "animation": "images/ambient/rubble_and_skulls",
      "canStep": true,
      "text": "Epitaph, half-scoured: HERE LIES THE MARCH'S LAST KING, WHO WAS CROWNED TWICE - ONCE IN LIFE, AND ONCE, WORSE, AFTER."
    }
  },
  "ambientMarumiBaso": {
    "ref": "signPost",
    "properties": {
      "animation": "images/ambient/brazier",
      "canStep": true,
      "text": "The spiral mark of Marumi Baso, scratched fresh on every stone from Nouraajd to here. The cult was always going to end up at a barrow."
    }
  }
}
