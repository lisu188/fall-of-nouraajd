  "tiaraOfTheDrownedTithe": {
    "class": "CHelmet",
    "properties": {
      "animation": "images/items/helmets/crownofnightmares",
      "label": "Tiara of the Drowned Tithe",
      "description": "Deep-wrought gold in the exotic tradition of the Order of Dagon, cold as tarn-water and heavier than its size. It gilds the mind with drowned knowing, but the wearer's flesh forgets how to keep the sea out.",
      "tags": [
        "quest"
      ],
      "bonus": {
        "class": "CStats",
        "properties": {
          "agility": 5,
          "crit": 8,
          "intelligence": 14,
          "normalResist": -10,
          "stamina": -8,
          "strength": 2
        }
      },
      "power": 16
    }
  },
  "drownedTitheQuest": {
    "class": "DrownedTitheQuest",
    "properties": {
      "description": "Uncover the secret of the drowned altar at the heart of Vhul'Marn."
    }
  },
  "ambientDrownedGate": {
    "ref": "signPost",
    "properties": {
      "animation": "images/ambient/broken_fence",
      "canStep": true,
      "text": "The town gate is barred from the inside with net-rope and prayer; the mud outside is printed with wide, webbed feet."
    }
  },
  "ambientTitheLedger": {
    "ref": "signPost",
    "properties": {
      "animation": "images/ambient/notice_board",
      "canStep": true,
      "text": "Tithe ledger: gold given, fish given, sons and daughters given. The final column is only ever marked PAID."
    }
  },
  "ambientNetShrine": {
    "ref": "signPost",
    "properties": {
      "animation": "images/ambient/stone_shrine",
      "canStep": true,
      "text": "A shrine of knotted nets and fish-hooks. Beneath a graven fish-god someone has scratched: DAGON HEARS. MOTHER HYDRA ANSWERS."
    }
  },
  "ambientChildrenShoes": {
    "ref": "signPost",
    "properties": {
      "animation": "images/ambient/supply_pile",
      "canStep": true,
      "text": "Small shoes are lined up along the tide line, each pair tied with net-cord. None of them point back toward the land."
    }
  },
  "ambientBackwardPrayer": {
    "ref": "signPost",
    "properties": {
      "animation": "images/ambient/broken_fence",
      "canStep": true,
      "text": "A house door bears a prayer written backward, so that only the water on the far side could read it rightly."
    }
  },
  "ambientGoldOrnament": {
    "ref": "signPost",
    "properties": {
      "animation": "images/ambient/market_stall",
      "canStep": true,
      "text": "A pawn-stall of strange gold: tiaras and armlets in no earthly fashion, priced in nothing, taken by no one."
    }
  },
  "ambientScrubbedDoorstep": {
    "ref": "signPost",
    "properties": {
      "animation": "images/ambient/rubble_and_skulls",
      "canStep": true,
      "text": "This doorstep has been scrubbed pale, yet the tarn keeps seeping brine back up through the joints of the stone."
    }
  },
  "ambientEmptyBoats": {
    "ref": "signPost",
    "properties": {
      "animation": "images/ambient/broken_cart",
      "canStep": true,
      "text": "The fishing boats are all drawn up and empty. Their nets are dry. Whatever Vhul'Marn eats now, it does not row out for."
    }
  },
  "ambientBellWarning": {
    "ref": "signPost",
    "properties": {
      "animation": "images/ambient/signpost",
      "canStep": true,
      "text": "WARNING - Do not toll the causeway bell after the tide turns. What it calls no longer knows it was ever asked to leave."
    }
  },
  "ambientCyclopeanBlocks": {
    "ref": "signPost",
    "properties": {
      "animation": "images/ambient/dead_tree",
      "canStep": true,
      "text": "These squared blocks are older than the town, older than masons. Their angles meet where two right angles have no business meeting."
    }
  },
  "ambientDeepScales": {
    "ref": "signPost",
    "properties": {
      "animation": "images/ambient/hay_bales",
      "canStep": true,
      "text": "Grey-green scales cling to the causeway stones, sloughed by things shaped enough like men to wear a townsman's coat."
    }
  },
  "ambientDrownedLantern": {
    "ref": "signPost",
    "properties": {
      "animation": "images/ambient/street_lantern",
      "canStep": true,
      "text": "A lantern still burns beneath the water's skin, lighting no road for the living, only the long stair going down."
    }
  },
  "ambientObedPact": {
    "ref": "signPost",
    "properties": {
      "animation": "images/ambient/gravestone_cluster",
      "canStep": true,
      "text": "A captain's grave, empty. The stone reads only: HE BROUGHT THE BARGAIN HOME, AND THE BARGAIN OUTLIVED HIM."
    }
  },
  "ambientYhaNthlei": {
    "ref": "signPost",
    "properties": {
      "animation": "images/ambient/stone_well",
      "canStep": true,
      "text": "A well without a bottom. Pilgrims knelt here to whisper toward Y'ha-nthlei, the city of columns and wonder that waits under the tarn."
    }
  },
  "ambientHydraHymn": {
    "ref": "signPost",
    "properties": {
      "animation": "images/ambient/brazier",
      "canStep": true,
      "text": "Wax and fish-oil gutter at a hymn-post. The last verse, worn smooth by wet lips: we shall not die, we shall go down and dwell."
    }
  },
  "ambientAltarTithe": {
    "ref": "signPost",
    "properties": {
      "animation": "images/ambient/stone_shrine",
      "canStep": true,
      "text": "Before the altar the tithe is named plainly: leave your gold, take the gold that is offered, and wear it, and be welcomed under."
    }
  },
  "ambientStarsAreRight": {
    "ref": "signPost",
    "properties": {
      "animation": "images/ambient/campfire_cauldron",
      "canStep": true,
      "text": "Someone kept a tally of the nights the altar sang. The marks stop where a shaking hand wrote: the stars are almost right."
    }
  }
}
