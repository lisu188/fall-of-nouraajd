{
  "vhulmarnStart": {
    "class": "StartEvent",
    "properties": {
      "text": "The mire's black water gives way to Vhul'Marn, a fishing hamlet half-swallowed by a lightless tarn. Cyclopean blocks of some elder mason lean at angles that should not hold, and every flooded street runs toward one drowned altar. The town paid a tithe to the deep once. It has never stopped paying."
    }
  },
  "vhulmarnSign": {
    "ref": "signPost",
    "properties": {
      "text": "VHUL'MARN - THE DROWNED TITHE. Fish and gold for the deep; the deep keeps the rest."
    }
  },
