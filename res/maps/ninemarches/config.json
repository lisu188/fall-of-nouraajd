  "obeliskFields": {"class": "Obelisk", "properties": {"animation": "images/ambient/gravestone_cluster", "canStep": true, "text": "Fields Obelisk: 'The crown lies six sigils deep. The first is cut in the muster-fields, where the Marches first bled.'"}},
  "obeliskFen": {"class": "Obelisk", "properties": {"animation": "images/ambient/gravestone_cluster", "canStep": true, "text": "Fen Obelisk: 'The second sigil drowns with the plague-dead. Read it while the water holds still.'"}},
  "obeliskBarrows": {"class": "Obelisk", "properties": {"animation": "images/ambient/gravestone_cluster", "canStep": true, "text": "Barrows Obelisk: 'The third sigil sleeps under the dead kings. Do not wake more than the sigil.'"}},
  "obeliskAsh": {"class": "Obelisk", "properties": {"animation": "images/ambient/gravestone_cluster", "canStep": true, "text": "Ashmarch Obelisk: 'The fourth sigil burns in the pyre-waste. The cult tends its ash for this very hour.'"}},
  "obeliskCoast": {"class": "Obelisk", "properties": {"animation": "images/ambient/gravestone_cluster", "canStep": true, "text": "Coast Obelisk: 'The fifth sigil drowned off the tithe-coast, in sight of a city of columns under the tarn.'"}},
  "obeliskCold": {"class": "Obelisk", "properties": {"animation": "images/ambient/gravestone_cluster", "canStep": true, "text": "Cold Obelisk: 'The sixth and last sigil freezes in the cold reach, cut by a hand that had already stopped being a hand.'"}},
