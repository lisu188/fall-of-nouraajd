{
  "hearthfallStart": {
    "class": "HearthfallStart",
    "properties": {
      "text": "Hearthfall at last. Ten years of exile end at a village you no longer recognize: the granary burned, the square walled off, and the usurper's occupation banner nailed over your family's sigil. The watch-captain who holds the square knows your name. Make him regret that."
    }
  },
  "hearthfallSign": {
    "ref": "signPost",
    "properties": {
      "text": "HEARTHFALL - by order of the Usurper's watch: curfew at dusk, tithes at dawn, and no word spoken of the exiled Warden."
    }
  },
  "hearthfallQuest": {
    "class": "HearthfallQuest",
    "properties": {
      "description": "Retake the village of Hearthfall from the occupation watch."
    }
  },
  "elderMaren": {
