  "ambientBurnedGranary": {
    "ref": "signPost",
    "properties": {
      "animation": "images/ambient/rubble_and_skulls",
      "canStep": true,
      "text": "The granary is a black ribcage of beams. The occupation burned a winter's grain to teach the village what hunger obeys."
    }
  },
  "ambientTallyPost": {
    "ref": "signPost",
    "properties": {
      "animation": "images/ambient/notice_board",
      "canStep": true,
      "text": "A tithe tally hangs from the post. Every family's column ends the same way: owed, owed, owed."
    }
  },
  "ambientColdHearths": {
    "ref": "signPost",
    "properties": {
      "animation": "images/ambient/campfire_cauldron",
      "canStep": true,
      "text": "No chimney in Hearthfall has smoked since the watch came. The village that once warmed the marches now hoards its own embers."
    }
  }
