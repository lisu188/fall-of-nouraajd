{
  "usurpergateStart": {
    "class": "UsurpergateStart",
    "properties": {
      "text": "The Usurper's Gate. Ash rides the wind off the burned approach, and the curtain wall your grandmother raised now flies a stranger's colors. Behind the breach waits the man who took the keep, the marches, and your name. One court, one throne, one ending."
    }
  },
  "usurpergateSign": {
    "ref": "signPost",
    "properties": {
      "text": "THE WARDENSKEEP - trespassers will be hanged from the curtain wall. Signed, the Lord-Protector of the Marches."
    }
  },
  "usurpergateQuest": {
    "class": "UsurpergateQuest",
    "properties": {
      "description": "Breach the curtain wall, defeat the Usurper, and take back the obsidian throne."
    }
