{
  "ritualStart": {
    "class": "StartEvent",
    "properties": {
      "text": "Cold rain runs across broken stones as you enter the abandoned chapel. Three ritual anchors feed a stained-glass prison in the sanctum. Break the anchors, stop the binding, and free the captive before the final chant."
    }
  },
  "ritualQuest": {
    "class": "RitualQuest",
    "properties": {
      "description": "Find and disrupt the chapel ritual."
    }
  },
  "destroyAnchorsQuest": {
