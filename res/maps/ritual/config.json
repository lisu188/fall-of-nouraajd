  "chapelWarningDialog": {
    "class": "ChapelWarningDialog",
    "properties": {
      "states": [
        {
          "class": "CDialogState",
          "properties": {
            "stateId": "ENTRY",
            "text": "The witness clutches a broken rosary. Three anchors sustain the prison. Each moment of delay strengthens the chant.",
            "options": [
              {
                "class": "CDialogOption",
                "properties": {
                  "number": 0,
                  "nextStateId": "DETAIL",
                  "text": "Where are the anchors?"
                }
              },
              {
                "ref": "exitOption",
                "properties": {
                  "number": 1,
                  "text": "I understand."
                }
              }
            ]
          }
        },
        {
          "class": "CDialogState",
          "properties": {
            "stateId": "DETAIL",
            "text": "One anchor is in the outer chapel, one in the crypt, and one beside the sanctum glass. Break them all, then slay the ritual leader.",
            "options": [
              {
                "ref": "exitOption",
                "properties": {
                  "number": 0
                }
              }
            ]
          }
        }
      ]
    }
  },
  "capturedSoulDialog": {
    "class": "CapturedSoulDialog",
    "properties": {
      "states": [
        {
          "class": "CDialogState",
          "properties": {
            "stateId": "ENTRY",
            "text": "The captive trembles behind the stained glass, waiting for your decision.",
            "options": [
              {
                "class": "CDialogOption",
                "properties": {
                  "number": 0,
                  "condition": "can_free_captive",
                  "action": "free_captive",
                  "nextStateId": "GOOD_END",
                  "text": "Break the glass and pull the captive free."
                }
              },
              {
                "class": "CDialogOption",
                "properties": {
                  "number": 1,
                  "condition": "is_captive_lost",
                  "nextStateId": "BAD_END",
                  "text": "The soul is already bound."
                }
              },
              {
                "class": "CDialogOption",
                "properties": {
                  "number": 2,
                  "condition": "is_captive_freed",
                  "nextStateId": "GOOD_END",
                  "text": "The captive is already free."
                }
              },
              {
                "class": "CDialogOption",
                "properties": {
                  "number": 3,
                  "condition": "need_more_work",
                  "nextStateId": "LOCKED",
                  "text": "The prison still hums with ritual force."
                }
              },
              {
                "ref": "exitOption",
                "properties": {
                  "number": 4
                }
              }
            ]
          }
        },
        {
          "class": "CDialogState",
          "properties": {
            "stateId": "GOOD_END",
            "text": "The stained glass explodes outward. The captive survives, and the chapel falls silent.",
            "options": [
              {
                "ref": "exitOption",
                "properties": {
                  "number": 0
                }
              }
            ]
          }
        },
        {
          "class": "CDialogState",
          "properties": {
            "stateId": "BAD_END",
            "text": "Only an empty husk remains. The rite finished before you could intervene.",
            "options": [
              {
                "ref": "exitOption",
                "properties": {
                  "number": 0
                }
              }
            ]
          }
        },
        {
          "class": "CDialogState",
          "properties": {
            "stateId": "LOCKED",
            "text": "The prison is sealed. Destroy all anchors and end the ritual leader first.",
            "options": [
              {
                "ref": "exitOption",
                "properties": {
                  "number": 0
                }
              }
            ]
          }
        }
      ]
    }
  },
  "recordsDialog": {
    "class": "RecordsDialog",
    "properties": {
      "states": [
        {
          "class": "CDialogState",
          "properties": {
            "stateId": "ENTRY",
            "text": "Ritual records mention that every fifth chant draws new defenders from the crypt halls.",
            "options": [
              {
                "ref": "exitOption",
                "properties": {
                  "number": 0
                }
              }
            ]
          }
        }
      ]
    }
  }
